   "source": [
    "p19.data <- c(12, 56, 42, 21, 5, 18, 10, 3, 61, 34, 65, 24)\n",
    "(p19.array <- sort(p19.data))\n",
    "(p19.rev.array <- rev(p19.array))\n",
    "(p19.range <- diff(range(p19.array)))"
